@page
@model MeepleSystemClient.Pages.RegisterModel

@* 
- Displays a registration form
- Collects email + password + confirmation
- Sends data to RegisterModel.OnPostAsync()
- Displays errors if something goes wrong
- Links back to login 
*@


@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>

    <div class="login-container">
        <div class="login-card">

            <h2>Create Account</h2>

            <form method="post">

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" class="form-input" placeholder="Enter your email" />
                </div>
                

                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-input" />
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-input" />
                </div>

                <button type="submit" class="login-btn">Register</button>

            </form>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="error">@Model.ErrorMessage</p>
            }

            <p style="margin-top:10px;">
                Already have an account?
                <a asp-page="/Login">Login</a>
            </p>

        </div>
    </div>

</body>
</html>
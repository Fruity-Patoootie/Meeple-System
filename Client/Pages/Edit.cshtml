@page
@model EditGameModel

<!-- ==================== MAIN ==================== -->
<div class="container d-flex justify-content-center mt-4">

    <div class="game-wrapper">

        <h2 class="game-title">
            Edit Game
        </h2>

        <div class="filter-panel p-4 w-100">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger text-center">
                    @Model.ErrorMessage
                </div>
            }

            <!-- IMAGE PREVIEW -->
            <div class="mt-2 text-center">

                <img src="@(Model.Game.ImageLocation ?? "/images/logo.png")"
                     class="img-fluid rounded shadow"
                     style="
                        width: 260px;
                        height: 260px;
                        object-fit: contain;
                        background: white;
                        border-radius: 10px;
                        padding: 10px;
                        border: 1px solid #ccc;"/>
                <div class="mt-2">
                    <small class="text-dark d-block mt-1">
                        Current Game Image
                    </small>
                </div>

            </div>

            <!-- ================= MAIN FORM ================= -->
            <form method="post">

                <!-- BASIC INFO -->
                <h5 class="mt-3">Basic Info</h5>

                <div class="mb-2">
                    <label>Title</label>

                    <input asp-for="Game.Title"
                           class="form-control"
                           readonly />
                </div>

                <div class="mb-2">
                    <label>Barcode</label>

                    <input asp-for="Game.Barcode"
                           class="form-control"
                           maxlength="13"
                           inputmode="numeric"
                           pattern="[0-9]*" />
                </div>

                <div class="mb-2">
                    <label>Style ID</label>

                    <input asp-for="Game.StyleId"
                           type="number"
                           class="form-control" />
                </div>

                <!-- GAME DETAILS -->
                <h5 class="mt-3">Game Details</h5>

                <div class="row">

                    <div class="col">
                        <label>Min Players</label>

                        <input asp-for="Game.MinPlayers"
                               type="number"
                               class="form-control" />
                    </div>

                    <div class="col">
                        <label>Max Players</label>

                        <input asp-for="Game.MaxPlayers"
                               type="number"
                               class="form-control" />
                    </div>

                </div>

                <div class="row mt-2">

                    <div class="col">
                        <label>Min Duration (minutes)</label>

                        <input asp-for="Game.MinDuration"
                               type="number"
                               class="form-control" />
                    </div>

                    <div class="col">
                        <label>Max Duration (minutes)</label>

                        <input asp-for="Game.MaxDuration"
                               type="number"
                               class="form-control" />
                    </div>

                </div>

                <div class="mt-2">
                    <label>Weight (complexity)</label>

                    <input asp-for="Game.Weight"
                           type="number"
                           step="0.01"
                           min="0"
                           max="99.99"
                           class="form-control" />
                </div>

                <!-- PLAYERS -->
                <h5 class="mt-3">Players</h5>

                <div class="mb-2">
                    <label>Recommended Players</label>

                    <input asp-for="Game.RecommendedPlayers"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Best Players</label>

                    <input asp-for="Game.BestPlayers"
                           class="form-control" />
                </div>

                <!-- PURCHASE -->
                <h5 class="mt-3">Purchase</h5>

                <div class="mb-2">
                    <label>Cost ($)</label>

                    <input asp-for="Game.Cost"
                           type="number"
                           step="0.01"
                           min="0"
                           max="999.99"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Date Acquired</label>

                    <input asp-for="Game.DateAcquired"
                           type="date"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Supplier</label>

                    <input asp-for="Game.SupplierName"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Seller</label>

                    <input asp-for="Game.SellerName"
                           class="form-control" />
                </div>

                <!-- ADDITIONAL -->
                <h5 class="mt-3">Additional</h5>

                <div class="mb-2">
                    <label>Location</label>

                    <input asp-for="Game.LocationName"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Image URL</label>

                    <input asp-for="Game.ImageLocation"
                           class="form-control" />
                </div>

                <div class="mb-2">
                    <label>BGG Game ID</label>

                    <input asp-for="Game.BggGameId"
                           type="number"
                           class="form-control" />
                </div>

                <div class="form-check mt-2">

                    <input type="hidden" asp-for="Game.Expansion" />
                    <input type="hidden" asp-for="Game.NeedsAddedToBgg" />

                    <div class="form-check mt-2">

                        <input asp-for="Game.Expansion"
                               class="form-check-input" />

                        <label class="form-check-label">
                            Expansion
                        </label>

                    </div>

                    <div class="form-check">

                        <input asp-for="Game.NeedsAddedToBgg"
                               class="form-check-input" />

                        <label class="form-check-label">
                            Needs BGG Entry
                        </label>

                    </div>
                <!-- BUTTONS -->
                <div class="text-center mt-3 d-flex justify-content-between">

                    <button type="submit"
                            class="btn export-btn w-50 me-2">

                        Save Changes

                    </button>

                    <a asp-page="/Details"
                           asp-route-title="@Model.Game.Title"
                           class="btn btn-secondary w-50">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>